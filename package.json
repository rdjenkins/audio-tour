{
  "name": "audio-tour-player",
  "version": "1.0.10",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "sw.js",
    "LICENSE"
  ],
  "main": "./dist/audio-tour-player.js",
  "module": "./dist/audio-tour-player.js",
  "exports": {
    ".": {
      "import": "./dist/audio-tour-player.js",
      "require": "./dist/audio-tour-player.umd.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "keywords": [
    "web-component",
    "audio-player",
    "pwa",
    "offline-first",
    "tour-guide"
  ],
  "author": "Dean Jenkins of CelticQuietPlaces.com",
  "license": "MIT",
  "scripts": {
    "dev": "npm run copy-sw && vite",
    "build": "npm run copy-sw && vite build",
    "preview": "npm run copy-sw && vite preview",
    "prepare-demo": "node prepare-site.js && echo 'deprecated - use audio-tour-player-example instead'",
    "copy-sw": "echo '// DO NOT EDIT THIS COPY OF sw.js' | cat - sw.js > public/sw.js"
  },
  "devDependencies": {
    "vite": "^8.0.0"
  },
  "dependencies": {
    "terser": "^5.46.1"
  }
}
